{
  "enabled": {
    "description": "是否启用该插件（总开关）",
    "type": "bool",
    "default": true
  },
  "debug_log": {
    "description": "是否输出详细调试日志",
    "type": "bool",
    "default": true,
    "hint": "关掉他，Astrbot日志将容不下他，并且你不知道他出了什么问题"
  },
  "personality_custom": {
    "description": "自定义人格描述",
    "type": "text",
    "default": "",
    "hint": "例如：你是一只傲娇的猫娘，说话带喵尾。"
  },
  "enable_context_history": {
    "description": "是否读取上下文历史消息来延续话题",
    "type": "bool",
    "default": true,
    "hint": "将聊天的上下文注入提示词内一同输入给大模型"
  },
  "group_enabled": {
    "description": "群聊主动发言",
    "type": "bool",
    "default": false
  },
  "group_start_time": {
    "description": "群聊允许发言开始时间",
    "type": "string",
    "default": "08:00",
    "hint": "格式必须为 HH:MM"
  },
  "group_end_time": {
    "description": "群聊允许发言结束时间",
    "type": "string",
    "default": "23:00",
    "hint": "格式必须为 HH:MM"
  },
  "group_allowed_ids": {
    "description": "群聊白名单（群ID列表）",
    "type": "list",
    "default": [123456789],
    "hint": "留空则为全部群聊"
  },
  "group_silence_wait": {
    "description": "群聊静默等待时间（分钟）",
    "type": "int",
    "default": 10
  },
  "group_phase1_duration": {
    "description": "群聊第一阶段窗口时长（分钟）",
    "type": "int",
    "default": 40
  },
  "group_phase1_prob": {
    "description": "群聊第一阶段触发概率（0~1）",
    "type": "float",
    "default": 0.15
  },
  "group_phase2_duration": {
    "description": "群聊第二阶段窗口时长（分钟）",
    "type": "int",
    "default": 60
  },
  "group_phase2_prob": {
    "description": "群聊第二阶段触发概率（0~1）",
    "type": "float",
    "default": 0.6
  },
  "group_check_interval": {
    "description": "群聊检测间隔（分钟）",
    "type": "int",
    "default": 8,
    "hint": "多久进行一次概率检测"
  },
  "private_enabled": {
    "description": "私聊主动发言",
    "type": "bool",
    "default": false
  },
  "private_start_time": {
    "description": "私聊允许发言开始时间",
    "type": "string",
    "default": "08:00",
    "hint": "格式必须为 HH:MM"
  },
  "private_end_time": {
    "description": "私聊允许发言结束时间",
    "type": "string",
    "default": "23:00",
    "hint": "格式必须为 HH:MM"
  },
  "private_allowed_ids": {
    "description": "私聊白名单（用户ID列表）",
    "type": "list",
    "default": [987654321],
    "hint": "留空则为全部私聊"
  },
  "private_silence_wait": {
    "description": "私聊静默等待时间（分钟）",
    "type": "int",
    "default": 10
  },
  "private_phase1_duration": {
    "description": "私聊第一阶段窗口时长（分钟）",
    "type": "int",
    "default": 40
  },
  "private_phase1_prob": {
    "description": "私聊第一阶段触发概率（0~1）",
    "type": "float",
    "default": 0.3
  },
  "private_phase2_duration": {
    "description": "私聊第二阶段窗口时长（分钟）",
    "type": "int",
    "default": 60
  },
  "private_phase2_prob": {
    "description": "私聊第二阶段触发概率（0~1）",
    "type": "float",
    "default": 0.8
  },
  "private_check_interval": {
    "description": "私聊检测间隔（分钟）",
    "type": "int",
    "default": 8,
    "hint": "多久进行一次概率检测"
  },
  "weight_history": {
    "description": "历史话题权重",
    "type": "int",
    "default": 1,
    "hint": "全局有效"
  },
  "weight_knowledge": {
    "description": "知识话题权重",
    "type": "int",
    "default": 1,
    "hint": "全局有效"
  },
  "weight_preset": {
    "description": "预设话题权重",
    "type": "int",
    "default": 1,
    "hint": "全局有效"
  },
  "weight_custom": {
    "description": "自定义话题权重",
    "type": "int",
    "default": 1,
    "hint": "全局有效"
  },
  "custom_topics": {
    "description": "自定义话题关键词列表",
    "type": "list",
    "default": ["美食", "天气", "原神"],
    "hint": "全局有效"
  },
  "llm_provider": {
    "description": "LLM 提供商",
    "type": "string",
    "default": "openai",
    "hint": "如 openai/deepseek/custom，留空则使用系统默认"
  },
  "llm_api_key": {
    "description": "API Key",
    "type": "string",
    "default": "",
    "hint": "留空则使用系统默认 LLM"
  },
  "llm_base_url": {
    "description": "API Base URL（可选）",
    "type": "string",
    "default": ""
  },
  "llm_model": {
    "description": "模型ID",
    "type": "string",
    "default": "",
    "hint": "如 DeepSeek/deepseek-v4-flash"
  },
  "learning_status": {
    "description": "学习状态（只读）",
    "type": "text",
    "default": "尚未学习，请等待首次每日学习任务运行。",
    "hint"每次点开插件设置会自更新，前提是你有学习任务"
  }
}
